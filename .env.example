# Local (untracked) native build overrides.
# Copy this file to .env and adjust values for your machine.

# Optional: fallback Windows vcpkg location used only when
# -Pnative.vcpkgRoot and VCPKG_ROOT are not set, and third_party/vcpkg is absent.
NATIVE_DEFAULT_WINDOWS_VCPKG_ROOT=C:/Programs/Microsoft Visual Studio/vcpkg

# Optional explicit roots used by native build
# VCPKG_ROOT=C:/Programs/Microsoft Visual Studio/vcpkg
# OPENSSL_ROOT_DIR=C:/Programs/Microsoft Visual Studio/vcpkg/installed/x64-windows