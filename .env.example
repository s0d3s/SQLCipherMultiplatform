# Local (untracked) native build overrides.
# Copy this file to .env and adjust values for your machine.

# Conan 2 executable and profiles used by :native-bridge tasks.
# Default executable is "conan" and default profile is "default".
# NATIVE_CONAN_EXECUTABLE=C:/Python312/Scripts/conan.exe
# NATIVE_CONAN_PROFILE=default
# NATIVE_CONAN_BUILD_PROFILE=default

# Optional override for Conan output folder used by native build.
# NATIVE_CONAN_OUTPUT_DIR=E:/path/to/SQLCipherMultiplatform/native-bridge/build/conan